# ---------------------------------------------------------------------------
# collabgraph — environment configuration
#
# Copy this file to `.env` (which is gitignored) and edit the values to fit
# your deployment:
#
#   cp .env.example .env
#
# All variables are read by `collabgraph.config.load_settings()` via
# `python-dotenv`, so any process spawned from the project root (CLI, web
# app, notebook) picks them up automatically.
# ---------------------------------------------------------------------------

# Filesystem path to the embedded Kuzu database directory. Will be created
# (along with any missing parent directories) on first init / ingest.
#
# Backups: just tar the directory:
#   tar czf backup.tgz data/collabgraph.kuzu data/collaborators.xlsx
COLLABGRAPH_DB_PATH=./data/collabgraph.kuzu
