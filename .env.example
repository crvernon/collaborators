# ---------------------------------------------------------------------------
# collabgraph — environment configuration
#
# Copy this file to `.env` (which is gitignored) and edit the values to match
# your Neo4j instance:
#
#   cp .env.example .env
#
# All variables are read by `collabgraph.config.load_settings()` via
# `python-dotenv`, so any process spawned from the project root (CLI, web
# app, notebook) picks them up automatically.
# ---------------------------------------------------------------------------

# Bolt URI for your Neo4j instance.
# Common values:
#   bolt://localhost:7687              (local Neo4j Desktop / standalone)
#   neo4j://<host>:7687                (clustered / routing-aware)
#   neo4j+s://<host>.databases.neo4j.io (Aura — TLS)
NEO4J_URI=bolt://localhost:7687

# Database username. Required.
NEO4J_USER=neo4j

# Database password. Required. Do NOT commit your real password.
NEO4J_PASSWORD=change-me

# Target database name (Neo4j 4+ supports multi-db). Defaults to "neo4j".
NEO4J_DATABASE=neo4j
